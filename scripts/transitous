#!/usr/bin/env python3
"""
Transitous CLI — Route planning via the Transitous MOTIS API.

USAGE:
    transitous route "Großburgwedel" "Hannover"
    transitous route --from 52.509,9.858 --to 52.377,9.741 --modes RAIL,BUS
    transitous route "Olbia" "Hannover" --date 2026-07-04 --modes AIRPLANE
    transitous stop "Hannover Hbf"

No API key. No IP blocks. Stdlib only.
"""

import json
import sys
import urllib.request
import urllib.parse
import datetime
import argparse

API_BASE = "https://api.transitous.org"
UA = "TransitousCLI/1.0 (https://github.com/philbob500/hermes-shared-skills)"

MODE_EMOJI = {
    "WALK": "🚶", "BUS": "🚌", "TRAM": "🚊", "SUBWAY": "🚇",
    "RAIL": "🚂", "REGIONAL_RAIL": "🚃", "HIGHSPEED_RAIL": "🚄",
    "LONG_DISTANCE": "🚅", "COACH": "🚍", "FERRY": "⛴️",
    "AIRPLANE": "✈️", "GONDOLA": "🚡", "AERIAL_LIFT": "🚡",
    "FUNICULAR": "🚞", "BIKE": "🚲", "CAR": "🚗",
}


def api(path, params=None):
    url = f"{API_BASE}{path}"
    if params:
        url += "?" + urllib.parse.urlencode(params, doseq=True)
    req = urllib.request.Request(url, headers={"User-Agent": UA, "Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read())


def cmd_route(args):
    from_place = args.from_place or args.origin
    to_place = args.to_place or args.dest

    if not from_place or not to_place:
        print("ERROR: --from/--to required, or pass as positional args", file=sys.stderr)
        sys.exit(1)

    if args.date:
        try:
            dt = datetime.datetime.fromisoformat(args.date)
        except ValueError:
            print(f"ERROR: bad date format '{args.date}' - use YYYY-MM-DD or ISO 8601", file=sys.stderr)
            sys.exit(1)
    else:
        dt = datetime.datetime.now(datetime.timezone.utc)

    modes = args.modes or "TRANSIT"

    # If names look like coordinates, use as-is; otherwise search stops
    def resolve(place):
        import math
        place = place.strip()
        if "," in place and all(p.replace(".", "").replace("-", "").isdigit() for p in place.split(",", 1)):
            return place
        # Name lookup via geocoding
        try:
            q = urllib.parse.quote(place)
            req = urllib.request.Request(
                f"{API_BASE}/api/v1/geocode?text={q}",
                headers={"User-Agent": UA, "Accept": "application/json"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read())
            # Response is a flat array of stop objects
            stops = data if isinstance(data, list) else data.get("stops", [])
            if not stops:
                print(f"ERROR: no stop found for '{place}'", file=sys.stderr)
                sys.exit(1)
            best = stops[0]
            lat = best.get("lat")
            lon = best.get("lon")
            sys.stderr.write(f"  → '{place}' → {best['name']} ({lat:.6f},{lon:.6f})\n")
            return f"{lat},{lon}"
        except Exception as e:
            print(f"ERROR resolving '{place}': {e}", file=sys.stderr)
            sys.exit(1)

    from_resolved = resolve(from_place)
    to_resolved = resolve(to_place)

    params = {
        "fromPlace": from_resolved,
        "toPlace": to_resolved,
        "numItineraries": args.num or 3,
        "transitModes": modes,
        "maxTransfers": args.max_transfers or 5,
        "maxTravelTime": args.max_time or 2880,
        "time": dt.strftime("%Y-%m-%dT%H:%M:%SZ"),
    }

    try:
        data = api("/api/v6/plan", params)
    except Exception as e:
        print(f"ERROR: API call failed: {e}", file=sys.stderr)
        sys.exit(1)

    its = data.get("itineraries", [])
    if not its:
        print(f"No routes found {from_place} → {to_place}")
        return

    print(f"\n{from_place} → {to_place}")
    print(f"  {dt.strftime('%a %d.%m.%Y %H:%M')}  ·  {len(its)} routes\n")

    for i, it in enumerate(its[: args.num or 3]):
        dur_h = it["duration"] // 3600
        dur_m = (it["duration"] % 3600) // 60
        start = it["startTime"][:16].replace("T", " ")
        end = it["endTime"][:16].replace("T", " ")
        transfers = it.get("transfers", 0)

        print(f"#{i+1}  {start} → {end}  ({dur_h}h {dur_m}m, {transfers}x)")
        print("-" * 60)

        for leg in it["legs"]:
            m = leg["mode"]
            emoji = MODE_EMOJI.get(m, "❓")
            if m == "WALK":
                dist = leg.get("distance", 0)
                print(f"  {emoji}  Fußweg {int(dist)}m")
                continue

            route = leg.get("route", "") or ""
            frm = leg["from"]["name"]
            to = leg["to"]["name"]
            dep = leg["from"].get("scheduledDeparture", "")[:16].replace("T", " ") or "??"
            arr = leg["to"].get("scheduledArrival", "")[:16].replace("T", " ") or "??"

            print(f"  {emoji}  {m:17s} {route:8s} {dep} → {arr}")
            print(f"         {frm}")
            print(f"         {to}")

        print()


def cmd_stop(args):
    query = args.query
    q = urllib.parse.quote(query)
    try:
        req = urllib.request.Request(
            f"{API_BASE}/api/v1/geocode?text={q}",
            headers={"User-Agent": UA, "Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=15) as resp:
            data = json.loads(resp.read())
    except Exception as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)

    stops = data if isinstance(data, list) else []
    if not stops:
        print(f"No stops found for '{query}'")
        return

    print(f"\nStops matching '{query}':")
    for s in stops[:10]:
        sid = s.get("id", s.get("stopId", "?"))
        name = s["name"]
        lat = s.get("lat", 0)
        lon = s.get("lon", 0)
        print(f"  {sid:45s} {name:40s} ({lat:.6f},{lon:.6f})")


def main():
    parser = argparse.ArgumentParser(description="Transitous CLI — public transport routing")
    sub = parser.add_subparsers(dest="command")
    sub.required = True

    # route
    r = sub.add_parser("route", help="Plan a route A→B")
    r.add_argument("origin", nargs="?", help="From: name or lat,lon")
    r.add_argument("dest", nargs="?", help="To: name or lat,lon")
    r.add_argument("--from", dest="from_place", help="From: name or lat,lon")
    r.add_argument("--to", dest="to_place", help="To: name or lat,lon")
    r.add_argument("--date", help="Date/time (ISO 8601). Default: now")
    r.add_argument("--modes", default="TRANSIT", help="Comma-separated: RAIL,BUS,AIRPLANE,TRANSIT")
    r.add_argument("--num", type=int, default=3, help="Number of routes (default: 3)")
    r.add_argument("--max-transfers", type=int, default=5)
    r.add_argument("--max-time", type=int, default=2880, help="Max travel time in minutes")
    r.set_defaults(func=cmd_route)

    # stop
    s = sub.add_parser("stop", help="Search stops/stations")
    s.add_argument("query", help="Stop name")
    s.set_defaults(func=cmd_stop)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
